{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Loop Task",
  "type": "object",
  "required": [
    "task_id",
    "created_at",
    "title",
    "goal",
    "context",
    "acceptance_criteria",
    "required_evidence",
    "priority",
    "status"
  ],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "goal": {
      "type": "string"
    },
    "context": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "required_evidence": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "priority": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "status": {
      "type": "string",
      "enum": ["open", "in_progress", "success", "partial_success", "blocked", "failed", "cancelled"]
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes_for_executor": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
